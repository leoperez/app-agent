// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// This is your updated Prisma schema file,
// now store-agnostic and accommodating both App Store and Google Play Store.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id             String         @id @default(cuid())
  name           String?
  email          String?        @unique
  emailVerified  DateTime?
  image          String?
  locale         String?
  createdAt      DateTime       @default(now())
  accounts       Account[]
  sessions       Session[]
  teams          UserTeam[]

  // Notification preferences
  notifyCompetitorChanges Boolean @default(true)
  weeklyDigestEnabled     Boolean @default(true)  // Receive weekly ASO digest email
  slackWebhookUrl         String? // Optional Slack incoming webhook URL for alerts
  ratingAlertThreshold    Float?  // Alert when app rating drops below this value (e.g. 4.0)

  // Stripe subscription fields
  plan           String         @default("free")
  stripeId       String?        @unique // Stripe subscription / customer ID
  subscriptionId String?        @unique // Stripe subscription ID
  startsAt       DateTime?      // Stripe subscription start date
  endsAt         DateTime?      // Stripe subscription end date
}

model Team {
  id           String        @id @default(cuid())
  name         String
  users        UserTeam[]
  invitations  Invitation[]
  sentEmails   SentEmail[]
  apps         App[]         // Holds apps for this team

  // Credentials for App Store Connect
  appStoreConnectPrivateKey String? // Private key for App Store Connect
  appStoreConnectKeyId      String? // Key ID for App Store Connect
  appStoreConnectIssuerId   String? // Issuer ID for App Store Connect
  appStoreConnectJWT        String?
  appStoreConnectJWTExpiresAt DateTime?

  // Credentials for Google Play Store
  googleServiceAccountKey Json? // Service Account Key JSON for Google Play

  // Stripe subscription fields
  plan           String    @default("free")
  stripeId       String?   @unique // Stripe customer ID
  subscriptionId String?   @unique // Stripe subscription ID
  startsAt       DateTime? // Stripe subscription start date
  endsAt         DateTime? // Stripe subscription end date
  canceledAt     DateTime? // Stripe subscription canceled date

  limits        Json?    // Plan limits, e.g., {apps: 1, users: 1}
  requiresApproval Boolean @default(false) // Gate publishes behind an approval workflow
  publishApprovals PublishApproval[]
  notifications          Notification[]
  descriptionTemplates   DescriptionTemplate[]
  reviewTemplates        ReviewTemplate[]
  autoReplyRules         ReviewAutoReplyRule[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  MANAGER
  MEMBER
}

model UserTeam {
  role   Role   @default(MEMBER)
  userId String
  teamId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([userId, teamId])
  @@index([userId])
  @@index([teamId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Invitation {
  email     String
  expires   DateTime
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  token     String   @unique

  @@unique([email, teamId])
}

enum EmailType {
  FIRST_TRIAL_END_REMINDER_EMAIL
  FINAL_TRIAL_END_REMINDER_EMAIL
}

model SentEmail {
  id         String    @id @default(cuid())
  type       EmailType
  recipient  String    // Email address of the recipient
  marketing  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  teamId     String
  team       Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

enum Store {
  APPSTORE
  GOOGLEPLAY
}

enum Platform {
  IOS
  ANDROID
  MACOS
  TVOS
}

model App {
  id             String    @id @default(cuid())
  teamId         String
  team           Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  store          Store
  platform       Platform
  storeAppId     String    // App ID in the respective store (e.g., bundle ID or package name)
  primaryLocale  String?

  // Common fields
  title            String?  // App name
  subtitle         String?  // App subtitle (Apple)
  summary          String?  // App summary (Google)
  developer        String?
  developerId      String?
  developerEmail   String?
  developerWebsite String?
  developerAddress String?
  privacyPolicyUrl String?
  iconUrl          String?
  headerImageUrl   String?
  videoUrl         String?
  videoImageUrl    String?
  adSupported      Boolean?
  containsAds      Boolean?
  released         DateTime?
  shortDescription String?

  versions           AppVersion[]
  localizations      AppLocalization[]
  asoKeywords        AsoKeyword[]
  asoKeywordRankings AsoKeywordRanking[]
  competitors        Competitor[]
  analytics          AppAnalytics[]
  whatsNewHistory    WhatsNewHistory[]
  metadataHistory    MetadataHistory[]
  storeExperiments   StoreExperiment[]
  metadataVariants    MetadataVariant[]
  ratingSnapshots     AppRatingSnapshot[]
  healthSnapshots     AsoHealthSnapshot[]
  reviews             AppReview[]
  autoReplyRules      ReviewAutoReplyRule[]
  scheduledPublishes  ScheduledPublish[]
  searchAdsMetrics    SearchAdsMetric[]
  screenshotSets      ScreenshotSet[]

  isStaged        Boolean   @default(false)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([teamId])
  @@index([store])
  @@index([platform])
  @@unique([store, storeAppId], name: "store_storeAppId")
}

model AppVersion {
  id              String    @id @default(cuid())
  appId           String
  app             App       @relation(fields: [appId], references: [id], onDelete: Cascade)
  version         String
  appInfoId       String?   // Reference to the app info record in App Store Connect
  releaseType     String?
  state           String?
  submission      String?
  platform        Platform
  minOsVersion    String?   // Minimum OS version required

  // Google Play-specific fields
  size                   String?
  installs               String?
  minInstalls            Int?
  realInstalls           Int?
  androidVersion         String?
  androidVersionText     String?
  score                  Float?
  ratings                Int?
  reviews                Int?
  histogram              Json?
  price                  Float?
  free                   Boolean?
  currency               String?
  priceText              String?
  offersIAP              Boolean?
  IAPRange               String?
  contentRating          String?
  contentRatingDescription String?
  update                 DateTime?

  localizations   AppLocalization[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([appId, version, platform], name: "appId_version_platform")
  @@index([appId])
  @@index([platform])
}

model AppLocalization {
  id                    String    @id @default(cuid())
  appId                 String
  appVersionId          String
  app                   App       @relation(fields: [appId], references: [id], onDelete: Cascade)
  appVersion            AppVersion @relation(fields: [appVersionId], references: [id], onDelete: Cascade)
  locale                String
  appInfoLocalizationId String?   // Only for App Store Connect

  // Common fields
  title                 String?
  subtitle              String?
  shortDescription      String?
  fullDescription       String?
  description           String?
  keywords              String?
  promotionalText       String?
  whatsNew              String?
  recentChanges         String?
  privacyPolicyUrl      String?
  privacyChoicesUrl     String?
  privacyPolicyText     String?
  marketingUrl          String?
  supportUrl            String?
  videoUrl              String?
  videoImageUrl         String?
  screenshots           Json?     // Array of screenshot URLs

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([appVersionId, locale], name: "appVersionId_locale")
  @@index([appId])
  @@index([appVersionId])
  @@index([locale])
}

model DescriptionTemplate {
  id               String   @id @default(cuid())
  teamId           String
  team             Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  store            String   // "APPSTORE" | "GOOGLEPLAY"
  name             String
  title            String?
  subtitle         String?
  keywords         String?  @db.Text
  description      String?  @db.Text
  shortDescription String?
  fullDescription  String?  @db.Text
  createdAt        DateTime @default(now())

  @@index([teamId, store])
}

model StoreExperiment {
  id          String   @id @default(cuid())
  appId       String
  app         App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  name        String
  hypothesis  String?  @db.Text
  field       String   // "title" | "shortDescription" | "fullDescription" | "icon" | "screenshots"
  variantA    String?  @db.Text
  variantB    String?  @db.Text
  status      String   @default("draft") // "draft" | "running" | "completed" | "cancelled"
  winner      String?  // "A" | "B" | null
  notes       String?  @db.Text
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([appId])
  @@index([appId, status])
}

model MetadataHistory {
  id               String   @id @default(cuid())
  appId            String
  app              App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  locale           String
  version          String?
  title            String?
  subtitle         String?
  keywords         String?  @db.Text
  description      String?  @db.Text
  shortDescription String?
  fullDescription  String?  @db.Text
  pushedAt         DateTime @default(now())

  @@index([appId, locale, pushedAt])
}

model WhatsNewHistory {
  id        String   @id @default(cuid())
  appId     String
  app       App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  locale    String
  text      String   @db.Text
  version   String?  // version string at time of push, if available
  pushedAt  DateTime @default(now())

  @@index([appId, locale, pushedAt])
}

model ScheduledPublish {
  id          String   @id @default(cuid())
  appId       String
  app         App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  scheduledAt DateTime
  status      String   @default("pending") // "pending" | "done" | "failed"
  executedAt  DateTime?
  error       String?
  createdAt   DateTime @default(now())

  @@index([appId])
  @@index([status, scheduledAt])
}

model AppReview {
  id         String   @id @default(cuid())
  appId      String
  app        App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  storeId    String
  version    String?
  score      Int
  title      String?
  body       String?  @db.Text
  reviewedAt DateTime
  locale     String?
  createdAt  DateTime @default(now())

  autoRepliedAt DateTime? // set when an auto-reply rule fired

  @@unique([appId, storeId])
  @@index([appId, reviewedAt])
  @@index([appId, score])
}

model AppRatingSnapshot {
  id          String   @id @default(cuid())
  appId       String
  app         App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  rating      Float    // current average rating
  ratingCount Int      // total number of ratings
  recordedAt  DateTime @default(now())

  @@unique([appId, recordedAt])
  @@index([appId, recordedAt])
}

model MetadataVariant {
  id          String    @id @default(cuid())
  appId       String
  app         App       @relation(fields: [appId], references: [id], onDelete: Cascade)
  locale      String
  name        String    // user-defined label e.g. "Short title test"
  title       String?
  subtitle    String?
  keywords    String?
  description String?   @db.Text
  isActive    Boolean   @default(false) // currently live on the store
  appliedAt   DateTime? // when this variant was last applied/pushed
  createdAt   DateTime  @default(now())

  @@index([appId, locale])
}

model AsoKeyword {
  id              String    @id @default(cuid())
  appId           String
  app             App       @relation(fields: [appId], references: [id], onDelete: Cascade)
  store           Store
  platform        Platform
  locale          String
  keyword                String
  trafficScore           Float?
  difficultyScore        Float?
  position               Int?
  overall                Float?
  positionAlertThreshold Int?    // alert when position drops below this rank (e.g. 10 = alert if >10)
  lastCheckedAt          DateTime  @default(now())
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@unique([appId, store, platform, locale, keyword])
  @@index([appId])
  @@index([store])
  @@index([platform])
  @@index([locale])
  @@index([keyword])
  @@index([lastCheckedAt])
}

model CompetitorChange {
  id             String     @id @default(cuid())
  competitorId   String
  competitor     Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  field          String     // "title" | "subtitle" | "description"
  previousValue  String?    @db.Text
  newValue       String?    @db.Text
  detectedAt     DateTime   @default(now())

  @@index([competitorId])
  @@index([detectedAt])
}

model AsoKeywordRanking {
  id         String   @id @default(cuid())
  appId      String
  app        App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  store      Store
  platform   Platform
  locale     String
  keyword    String
  position   Int?     // null = not in top 100
  recordedAt DateTime @default(now())

  @@index([appId, locale, keyword, recordedAt])
  @@index([appId])
  @@index([recordedAt])
}

model AppAnalytics {
  id            String   @id @default(cuid())
  appId         String
  app           App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  date          DateTime @db.Date
  impressions   Int?
  pageViews     Int?
  downloads     Int?
  sessions      Int?
  activeDevices Int?
  createdAt     DateTime @default(now())

  @@unique([appId, date])
  @@index([appId, date])
}

model Notification {
  id        String    @id @default(cuid())
  teamId    String
  team      Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  appId     String?
  type      String    // "keyword_drop" | "competitor_change" | "rating_drop" | "new_review"
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([teamId, readAt])
  @@index([teamId, createdAt])
}

model ReviewTemplate {
  id          String                @id @default(cuid())
  teamId      String
  team        Team                  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name        String
  body        String                @db.Text
  rating      Int?                  // optional: associate template with a star rating (1-5)
  createdAt   DateTime              @default(now())
  autoReplyRules ReviewAutoReplyRule[]

  @@index([teamId])
}

// Auto-reply rule: when a new review matches the rating range, reply with the template
model ReviewAutoReplyRule {
  id         String         @id @default(cuid())
  teamId     String
  team       Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  appId      String?        // null = all apps in team
  app        App?           @relation(fields: [appId], references: [id], onDelete: Cascade)
  minRating  Int            // 1-5
  maxRating  Int            // 1-5
  templateId String
  template   ReviewTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  enabled    Boolean        @default(true)
  createdAt  DateTime       @default(now())

  @@index([teamId])
}

model CronLog {
  id               String   @id @default(cuid())
  cronName         String
  status           String   // "success" | "error"
  recordsProcessed Int      @default(0)
  durationMs       Int      @default(0)
  errorMessage     String?  @db.Text
  runAt            DateTime @default(now())

  @@index([cronName, runAt])
  @@index([runAt])
}

model SearchAdsMetric {
  id          String   @id @default(cuid())
  appId       String
  app         App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  keyword     String
  date        DateTime @db.Date
  impressions Int      @default(0)
  taps        Int      @default(0)
  installs    Int      @default(0)
  spend       Float    @default(0)
  currency    String   @default("USD")
  createdAt   DateTime @default(now())

  @@unique([appId, keyword, date])
  @@index([appId, date])
}

model Competitor {
  id String @id @default(cuid())
  appId String
  app App @relation(fields: [appId], references: [id], onDelete: Cascade, map: "competitors")
  locale String
  competitorId String // store ID
  title String
  subtitle String?
  description String?
  iconUrl String?
  guessedKeywords String[]
  reviews Int @default(0)
  order Int @default(0)
  store Store
  changes CompetitorChange[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([appId, locale, competitorId], name: "appId_locale_competitorId")
  @@index([appId])
  @@index([locale])
  @@index([order])
}

// Daily snapshot of the computed ASO health score per app
model AsoHealthSnapshot {
  id         String   @id @default(cuid())
  appId      String
  app        App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  score      Int      // 0–100
  recordedAt DateTime @default(now())

  @@unique([appId, recordedAt])
  @@index([appId, recordedAt])
}

// Approval request before publishing metadata to the store
model PublishApproval {
  id          String    @id @default(cuid())
  teamId      String
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  appId       String
  requestedBy String    // userId of the requester
  summary     String    @db.Text  // human-readable summary of what will be published
  status      String    @default("pending") // "pending" | "approved" | "rejected"
  reviewedBy  String?   // userId of the reviewer
  reviewNote  String?   // optional reviewer comment
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([teamId, status])
  @@index([appId])
}

model UserFeedback {
  id        String   @id @default(cuid())
  userId    String?  // null if submitted anonymously
  email     String?
  message   String   @db.Text
  page      String?  // URL or route where feedback was submitted
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Screenshot Studio: saved sets of app store / google play screenshot designs
model ScreenshotSet {
  id       String @id @default(cuid())
  appId    String
  app      App    @relation(fields: [appId], references: [id], onDelete: Cascade)
  locale   String
  name     String @default("Untitled set")
  layoutId String // "centered" | "bottom-caption" | "split-left" | "split-right" | "hero"
  themeId  String // "midnight" | "ivory" | "violet" | "ocean" | "ember"
  fontId   String @default("system") // see FontId type
  // custom color overrides (optional)
  customBg      String?
  customText    String?
  customAccent  String?
  // gradient background: {type:"gradient",color1,color2,angle} or null for solid
  bgGradient    Json?
  // slides: array of SlideData (texts + badge + screenshotUrl)
  slides   Json   @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([appId])
  @@index([appId, locale])
}
